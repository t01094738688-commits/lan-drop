{
  "name": "shanchuan-ben",
  "version": "0.1.38",
  "private": true,
  "description": "Local LAN file, image, text transfer and quick notes between phone and computer.",
  "main": "desktop/main.js",
  "scripts": {
    "start": "node server.js",
    "desktop": "electron .",
    "build:win": "powershell -NoProfile -ExecutionPolicy Bypass -File ./build-windows.ps1 -Type installer",
    "build:win:portable": "powershell -NoProfile -ExecutionPolicy Bypass -File ./build-windows.ps1 -Type portable",
    "pack:win": "electron-builder --win portable",
    "dist:win": "electron-builder --win nsis",
    "pack:mac": "electron-builder --mac zip",
    "dist:mac": "electron-builder --mac dmg zip",
    "dist:linux": "electron-builder --linux AppImage deb"
  },
  "build": {
    "appId": "com.shanchuan.ben",
    "productName": "闪传本子",
    "executableName": "闪传本子",
    "directories": {
      "output": "release"
    },
    "files": [
      "build/**/*",
      "desktop/**/*",
      "installer/**/*",
      "public/**/*",
      "server.js",
      "package.json"
    ],
    "win": {
      "icon": "build/icon.ico",
      "target": [
        "portable",
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "include": "installer/installer.nsh"
    },
    "mac": {
      "icon": "build/icon.icns",
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.productivity"
    },
    "linux": {
      "icon": "build/icon.png",
      "maintainer": "t01094738688-commits <t01094738688-commits@users.noreply.github.com>",
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Utility"
    },
    "artifactName": "LAN-Drop-${version}-${os}-${arch}.${ext}"
  },
  "devDependencies": {
    "electron": "^42.3.0",
    "electron-builder": "^26.8.1"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "qrcode": "^1.5.4"
  },
  "author": "t01094738688-commits"
}
